---
import { Code } from "astro:components";
import ExampleBlock from "../ExampleBlock.astro";

const cssCode = `<div class="toast-demo-stack toast-demo-shell">
  <div class="toast-demo-controls">
    <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="success">Success</button>
    <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="error">Error</button>
    <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="loading">Loading → Success</button>
    <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="promise">Promise</button>
    <button data-toast-demo-clear data-toast-demo-target="toast-css">Clear</button>
  </div>

  <div data-slot="toast" id="toast-css" data-position="bottom-right" data-portal="true" class="toast-root">
    <template data-slot="toast-template">
      <li data-slot="toast-item" class="toast-item" role="status" aria-atomic="true">
        <div class="toast-copy">
          <strong data-slot="toast-title"></strong>
          <p data-slot="toast-description"></p>
        </div>
        <div class="toast-buttons">
          <button data-slot="toast-action" type="button"></button>
          <button data-slot="toast-close" type="button" aria-label="Close">×</button>
        </div>
      </li>
    </template>
    <ol data-slot="toast-viewport" aria-label="Notifications" class="toast-demo-viewport"></ol>
  </div>
</div>

<style>
  .toast-demo-shell {
    position: relative;
    min-height: 240px;
    border: 1px dashed #ccc;
    background: #f5f4f1;
    padding: 0.75rem;
  }

  .toast-demo-controls {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .toast-demo-controls button {
    font: inherit;
    font-size: 0.75rem;
    border: 1px solid #ccc;
    background: #faf9f7;
    padding: 0.35rem 0.55rem;
    cursor: pointer;
  }

  .toast-root {
    position: relative;
    min-height: 180px;
  }

  [data-slot="toast-viewport"] {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    width: min(22rem, calc(100vw - 2rem));
    height: var(--toast-stack-size, 0px);
    min-height: 1px;
    list-style: none;
    margin: 0;
    padding: 0;
    --toast-gap: 8;
    pointer-events: auto;
    z-index: 80;
  }

  [data-slot="toast-item"] {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    background: #1f1f1f;
    color: #f8f8f8;
    border: 1px solid #2f2f2f;
    padding: 0.7rem 0.75rem;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
    transform: translate3d(
        0,
        calc(var(--toast-index, 0) * 8px * var(--toast-stack-direction, -1)),
        0
      )
      scale(calc(1 - var(--toast-index, 0) * 0.04));
    opacity: calc(1 - var(--toast-index, 0) * 0.14);
    transition:
      transform 400ms ease,
      opacity 400ms ease,
      box-shadow 200ms ease;
    will-change: transform, opacity;
    pointer-events: auto;
  }

  [data-slot="toast-item"][data-front] {
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.32);
  }

  [data-slot="toast-viewport"][data-expanded] [data-slot="toast-item"] {
    transform: translate3d(
      0,
      calc(var(--toast-offset-y, 0px) * var(--toast-stack-direction, -1)),
      0
    );
    opacity: 1;
  }

  [data-slot="toast-item"][data-starting-style] {
    transform: translate3d(0, calc(var(--toast-enter-direction, var(--toast-stack-direction, -1)) * -160%), 0)
      scale(calc(1 - var(--toast-index, 0) * 0.04));
    opacity: 0;
  }

  [data-slot="toast-item"][data-ending-style] {
    transform: translate3d(0, calc(var(--toast-exit-direction, var(--toast-stack-direction, -1)) * -160%), 0)
      scale(calc(1 - var(--toast-index, 0) * 0.04));
    opacity: 0;
  }

  .toast-copy {
    min-width: 0;
  }

  .toast-copy strong {
    display: block;
    font-size: 0.8rem;
    margin-bottom: 0.2rem;
  }

  .toast-copy p {
    margin: 0;
    font-size: 0.73rem;
    color: #b5b5b5;
  }

  .toast-buttons {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
  }

  [data-slot="toast-action"],
  [data-slot="toast-close"] {
    font: inherit;
    font-size: 0.72rem;
    border: 1px solid #3b3b3b;
    background: transparent;
    color: #d9d9d9;
    padding: 0.2rem 0.4rem;
    cursor: pointer;
    line-height: 1;
  }

  [data-slot="toast-close"] {
    font-size: 0.8rem;
    padding: 0.2rem 0.35rem;
  }

  [data-slot="toast-item"][data-type="success"] {
    border-color: #2f7a56;
  }

  [data-slot="toast-item"][data-type="error"] {
    border-color: #8a3939;
  }

  [data-slot="toast-item"][data-type="warning"] {
    border-color: #8a6d2f;
  }
</style>`;

const tailwindCode = `<div class="toast-demo-stack relative min-h-[240px] border border-dashed border-[#ccc] bg-[#f5f4f1] p-3">
  <div class="mb-3 flex flex-wrap gap-2">
    <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="success">Success</button>
    <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="error">Error</button>
    <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="loading">Loading → Success</button>
    <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="promise">Promise</button>
    <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-clear data-toast-demo-target="toast-tw">Clear</button>
  </div>

  <div data-slot="toast" id="toast-tw" data-position="bottom-right" data-portal="true" class="relative min-h-[180px]">
    <template data-slot="toast-template">
      <li
        data-slot="toast-item"
        class="absolute inset-x-0 bottom-0 flex justify-between gap-3 border border-[#2f2f2f] bg-[#1f1f1f] p-3 text-[#f8f8f8] shadow-[0_10px_24px_rgba(0,0,0,0.22)]"
        role="status"
        aria-atomic="true"
      >
        <div class="min-w-0">
          <strong data-slot="toast-title" class="mb-1 block text-[0.8rem]"></strong>
          <p data-slot="toast-description" class="m-0 text-[0.73rem] text-[#b5b5b5]"></p>
        </div>
        <div class="flex items-start gap-1.5">
          <button data-slot="toast-action" type="button" class="border border-[#3b3b3b] bg-transparent px-1.5 py-1 text-[0.72rem] text-[#d9d9d9]"></button>
          <button data-slot="toast-close" type="button" aria-label="Close" class="border border-[#3b3b3b] bg-transparent px-1.5 py-1 text-[0.8rem] text-[#d9d9d9]">×</button>
        </div>
      </li>
    </template>
    <ol data-slot="toast-viewport" aria-label="Notifications" class="toast-demo-viewport m-0 list-none p-0"></ol>
  </div>
</div>

/* Keep stack/fan animations in plain CSS using runtime vars + data attrs */
[data-slot="toast-viewport"] {
  position: fixed;
  right: 1rem;
  bottom: 1rem;
  width: min(22rem, calc(100vw - 2rem));
  height: var(--toast-stack-size, 0px);
  min-height: 1px;
  --toast-gap: 8;
  pointer-events: auto;
  z-index: 80;
}

[data-slot="toast-item"] {
  transform: translate3d(
      0,
      calc(var(--toast-index, 0) * 8px * var(--toast-stack-direction, -1)),
      0
    )
    scale(calc(1 - var(--toast-index, 0) * 0.04));
  opacity: calc(1 - var(--toast-index, 0) * 0.14);
  transition:
    transform 400ms ease,
    opacity 400ms ease,
    box-shadow 200ms ease;
  will-change: transform, opacity;
  pointer-events: auto;
}

[data-slot="toast-viewport"][data-expanded] [data-slot="toast-item"] {
  transform: translate3d(
    0,
    calc(var(--toast-offset-y, 0px) * var(--toast-stack-direction, -1)),
    0
  );
  opacity: 1;
}

[data-slot="toast-item"][data-starting-style] {
  transform: translate3d(0, calc(var(--toast-enter-direction, var(--toast-stack-direction, -1)) * -160%), 0)
    scale(calc(1 - var(--toast-index, 0) * 0.04));
  opacity: 0;
}

[data-slot="toast-item"][data-ending-style] {
  transform: translate3d(0, calc(var(--toast-exit-direction, var(--toast-stack-direction, -1)) * -160%), 0)
    scale(calc(1 - var(--toast-index, 0) * 0.04));
  opacity: 0;
}`;
---

<ExampleBlock label="template cloning + stacked animations (hover/focus to expand)">
  <div slot="preview-css" class="toast-demo-stack toast-demo-shell">
    <div class="toast-demo-controls">
      <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="success">Success</button>
      <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="error">Error</button>
      <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="loading">Loading → Success</button>
      <button data-toast-demo-btn data-toast-demo-target="toast-css" data-toast-demo-kind="promise">Promise</button>
      <button data-toast-demo-clear data-toast-demo-target="toast-css">Clear</button>
    </div>

    <div data-slot="toast" id="toast-css" data-position="bottom-right" data-portal="true" class="toast-root">
      <template data-slot="toast-template">
        <li data-slot="toast-item" class="toast-item" role="status" aria-atomic="true">
          <div class="toast-copy">
            <strong data-slot="toast-title"></strong>
            <p data-slot="toast-description"></p>
          </div>
          <div class="toast-buttons">
            <button data-slot="toast-action" type="button"></button>
            <button data-slot="toast-close" type="button" aria-label="Close">×</button>
          </div>
        </li>
      </template>
      <ol data-slot="toast-viewport" aria-label="Notifications" class="toast-demo-viewport"></ol>
    </div>
  </div>

  <div slot="preview-tailwind" class="toast-demo-stack relative min-h-[240px] border border-dashed border-[#ccc] bg-[#f5f4f1] p-3">
    <div class="mb-3 flex flex-wrap gap-2">
      <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="success">Success</button>
      <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="error">Error</button>
      <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="loading">Loading → Success</button>
      <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-btn data-toast-demo-target="toast-tw" data-toast-demo-kind="promise">Promise</button>
      <button class="border border-[#ccc] bg-[#faf9f7] px-2 py-1 text-xs" data-toast-demo-clear data-toast-demo-target="toast-tw">Clear</button>
    </div>

    <div data-slot="toast" id="toast-tw" data-position="bottom-right" data-portal="true" class="relative min-h-[180px]">
      <template data-slot="toast-template">
        <li
          data-slot="toast-item"
          class="absolute inset-x-0 bottom-0 flex justify-between gap-3 border border-[#2f2f2f] bg-[#1f1f1f] p-3 text-[#f8f8f8] shadow-[0_10px_24px_rgba(0,0,0,0.22)]"
          role="status"
          aria-atomic="true"
        >
          <div class="min-w-0">
            <strong data-slot="toast-title" class="mb-1 block text-[0.8rem]"></strong>
            <p data-slot="toast-description" class="m-0 text-[0.73rem] text-[#b5b5b5]"></p>
          </div>
          <div class="flex items-start gap-1.5">
            <button data-slot="toast-action" type="button" class="border border-[#3b3b3b] bg-transparent px-1.5 py-1 text-[0.72rem] text-[#d9d9d9]"></button>
            <button data-slot="toast-close" type="button" aria-label="Close" class="border border-[#3b3b3b] bg-transparent px-1.5 py-1 text-[0.8rem] text-[#d9d9d9]">×</button>
          </div>
        </li>
      </template>
      <ol data-slot="toast-viewport" aria-label="Notifications" class="toast-demo-viewport m-0 list-none p-0"></ol>
    </div>
  </div>

  <p slot="note" class="mt-3">
    Uses runtime stack variables (<code>--toast-index</code>, <code>--toast-offset-y</code>) and presence attributes for entry/exit.
    Motion is transform/opacity-only with <code>will-change</code> for smooth compositing. Hover or focus within viewport to expand/fan
    the stack.
  </p>

  <Code slot="code-css" code={cssCode} lang="html" theme="vitesse-light" />
  <Code slot="code-tailwind" code={tailwindCode} lang="html" theme="vitesse-light" />
</ExampleBlock>

<style>
  .toast-demo-stack {
    position: relative;
    min-height: 240px;
    border: 1px dashed #c8c3bc;
    background:
      radial-gradient(circle at 15% 20%, #ffffff 0%, #f5f4f1 48%, #ece9e4 100%);
    padding: 0.85rem;
    overflow: hidden;
  }

  .toast-demo-stack [data-toast-demo-btn],
  .toast-demo-stack [data-toast-demo-clear] {
    font: inherit;
    font-size: 0.75rem;
    border: 1px solid #cfc8be;
    background: #fcfbf8;
    color: #2d2a27;
    border-radius: 0.4rem;
    padding: 0.3rem 0.6rem;
    cursor: pointer;
    transition: background-color 150ms ease, border-color 150ms ease;
  }

  .toast-demo-stack [data-toast-demo-btn]:hover,
  .toast-demo-stack [data-toast-demo-clear]:hover {
    background: #f2eee8;
    border-color: #b7aea3;
  }

  .toast-demo-stack [data-slot="toast"] {
    position: relative;
    min-height: 180px;
    isolation: isolate;
  }

  .toast-demo-viewport {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    width: min(22rem, calc(100vw - 2rem));
    height: var(--toast-stack-size, 0px);
    min-height: 1px;
    list-style: none;
    margin: 0;
    padding: 0;
    --toast-gap: 8;
    pointer-events: auto;
    z-index: 80;
  }

  .toast-demo-viewport [data-slot="toast-item"] {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1px solid #2f2f2f;
    border-radius: 0.8rem;
    background: linear-gradient(180deg, #272727 0%, #1f1f1f 100%);
    color: #f8f8f8;
    padding: 0.72rem 0.78rem;
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.24);
    transform: translate3d(
        0,
        calc(var(--toast-index, 0) * 8px * var(--toast-stack-direction, -1)),
        0
      )
      scale(calc(1 - var(--toast-index, 0) * 0.04));
    opacity: calc(1 - var(--toast-index, 0) * 0.14);
    transition:
      transform 400ms ease,
      opacity 400ms ease,
      box-shadow 200ms ease;
    will-change: transform, opacity;
    pointer-events: auto;
  }

  .toast-demo-viewport [data-slot="toast-item"][data-front] {
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.3);
  }

  .toast-demo-viewport[data-expanded] [data-slot="toast-item"] {
    transform: translate3d(
      0,
      calc(var(--toast-offset-y, 0px) * var(--toast-stack-direction, -1)),
      0
    );
    opacity: 1;
  }

  .toast-demo-viewport [data-slot="toast-item"][data-starting-style] {
    transform: translate3d(0, calc(var(--toast-enter-direction, var(--toast-stack-direction, -1)) * -160%), 0)
      scale(calc(1 - var(--toast-index, 0) * 0.04));
    opacity: 0;
  }

  .toast-demo-viewport [data-slot="toast-item"][data-ending-style] {
    transform: translate3d(0, calc(var(--toast-exit-direction, var(--toast-stack-direction, -1)) * -160%), 0)
      scale(calc(1 - var(--toast-index, 0) * 0.04));
    opacity: 0;
  }

  .toast-demo-viewport [data-slot="toast-title"] {
    display: block;
    font-size: 0.83rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }

  .toast-demo-viewport [data-slot="toast-description"] {
    margin: 0;
    font-size: 0.73rem;
    color: #b8b8b8;
  }

  .toast-demo-viewport [data-slot="toast-action"],
