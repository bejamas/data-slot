---
import { Code } from "astro:components";
import ExampleBlock from "../ExampleBlock.astro";

const cssCode = `<div data-slot="carousel" class="carousel">
  <div data-slot="carousel-content" class="carousel-content">
    <div data-slot="carousel-item" class="carousel-item">Slide 1</div>
    <div data-slot="carousel-item" class="carousel-item">Slide 2</div>
    <div data-slot="carousel-item" class="carousel-item">Slide 3</div>
  </div>

  <button data-slot="carousel-previous" class="carousel-nav carousel-prev" aria-label="Previous slide">
    ←
  </button>
  <button data-slot="carousel-next" class="carousel-nav carousel-next" aria-label="Next slide">
    →
  </button>
</div>

<style>
  .carousel {
    position: relative;
    width: 100%;
    max-width: 28rem;
    margin-inline: auto;
  }

  .carousel-content {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .carousel-content::-webkit-scrollbar {
    display: none;
  }

  .carousel-item {
    flex: 0 0 100%;
    min-width: 0;
    scroll-snap-align: start;
    border: 1px solid #d4d4d4;
    background: #fafafa;
    padding: 2rem;
    text-align: center;
  }

  .carousel-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2rem;
    height: 2rem;
    border: 1px solid #d4d4d4;
    background: #fff;
    cursor: pointer;
  }

  .carousel-nav:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .carousel-prev { left: 0.5rem; }
  .carousel-next { right: 0.5rem; }
</style>`;

const tailwindCode = `<div data-slot="carousel" class="relative mx-auto w-full max-w-md">
  <div
    data-slot="carousel-content"
    class="flex overflow-x-auto snap-x snap-mandatory [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
  >
    <div data-slot="carousel-item" class="min-w-0 shrink-0 grow-0 basis-full snap-start border border-neutral-300 bg-neutral-50 p-8 text-center">
      Slide 1
    </div>
    <div data-slot="carousel-item" class="min-w-0 shrink-0 grow-0 basis-full snap-start border border-neutral-300 bg-neutral-50 p-8 text-center">
      Slide 2
    </div>
    <div data-slot="carousel-item" class="min-w-0 shrink-0 grow-0 basis-full snap-start border border-neutral-300 bg-neutral-50 p-8 text-center">
      Slide 3
    </div>
  </div>

  <button
    data-slot="carousel-previous"
    class="absolute left-2 top-1/2 grid h-8 w-8 -translate-y-1/2 place-items-center border border-neutral-300 bg-white disabled:cursor-not-allowed disabled:opacity-45"
    aria-label="Previous slide"
  >
    ←
  </button>
  <button
    data-slot="carousel-next"
    class="absolute right-2 top-1/2 grid h-8 w-8 -translate-y-1/2 place-items-center border border-neutral-300 bg-white disabled:cursor-not-allowed disabled:opacity-45"
    aria-label="Next slide"
  >
    →
  </button>
</div>`;
---

<ExampleBlock label="Carousel">
  <div slot="preview-css" data-slot="carousel" class="carousel-css">
    <div data-slot="carousel-content" class="carousel-content-css">
      <div data-slot="carousel-item" class="carousel-item-css">Slide 1</div>
      <div data-slot="carousel-item" class="carousel-item-css">Slide 2</div>
      <div data-slot="carousel-item" class="carousel-item-css">Slide 3</div>
    </div>

    <button data-slot="carousel-previous" class="carousel-nav-css carousel-prev-css" aria-label="Previous slide">
      ←
    </button>
    <button data-slot="carousel-next" class="carousel-nav-css carousel-next-css" aria-label="Next slide">
      →
    </button>
  </div>

  <div slot="preview-tailwind" data-slot="carousel" class="relative mx-auto w-full max-w-md">
    <div
      data-slot="carousel-content"
      class="flex overflow-x-auto snap-x snap-mandatory [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      <div data-slot="carousel-item" class="min-w-0 shrink-0 grow-0 basis-full snap-start border border-neutral-300 bg-neutral-50 p-8 text-center">
        Slide 1
      </div>
      <div data-slot="carousel-item" class="min-w-0 shrink-0 grow-0 basis-full snap-start border border-neutral-300 bg-neutral-50 p-8 text-center">
        Slide 2
      </div>
      <div data-slot="carousel-item" class="min-w-0 shrink-0 grow-0 basis-full snap-start border border-neutral-300 bg-neutral-50 p-8 text-center">
        Slide 3
      </div>
    </div>

    <button
      data-slot="carousel-previous"
      class="absolute left-2 top-1/2 grid h-8 w-8 -translate-y-1/2 place-items-center border border-neutral-300 bg-white disabled:cursor-not-allowed disabled:opacity-45"
      aria-label="Previous slide"
    >
      ←
    </button>
    <button
      data-slot="carousel-next"
      class="absolute right-2 top-1/2 grid h-8 w-8 -translate-y-1/2 place-items-center border border-neutral-300 bg-white disabled:cursor-not-allowed disabled:opacity-45"
      aria-label="Next slide"
    >
      →
    </button>
  </div>

  <Code slot="code-css" code={cssCode} lang="html" theme="vitesse-light" />
  <Code slot="code-tailwind" code={tailwindCode} lang="html" theme="vitesse-light" />
</ExampleBlock>

<style>
  .carousel-css {
    position: relative;
    width: 100%;
    max-width: 28rem;
    margin-inline: auto;
  }

  .carousel-content-css {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .carousel-content-css::-webkit-scrollbar {
    display: none;
  }

  .carousel-item-css {
    flex: 0 0 100%;
    min-width: 0;
    scroll-snap-align: start;
    border: 1px solid #d4d4d4;
    background: #fafafa;
    padding: 2rem;
    text-align: center;
  }

  .carousel-nav-css {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2rem;
    height: 2rem;
    border: 1px solid #d4d4d4;
    background: #fff;
    cursor: pointer;
  }

  .carousel-nav-css:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .carousel-prev-css {
    left: 0.5rem;
  }

  .carousel-next-css {
    right: 0.5rem;
  }
</style>
