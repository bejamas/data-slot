<style>
  .command-root {
    width: min(100%, 26rem);
    border: 1px solid #d7d2cc;
    background: linear-gradient(180deg, #faf9f7 0%, #f4f0ea 100%);
    box-shadow: 0 18px 40px rgba(34, 27, 17, 0.08);
  }

  .command-root-dialog {
    width: 100%;
  }

  .command-field-label {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: #64584d;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .command-input-shell {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.8rem 0.9rem;
    border-bottom: 1px solid rgba(115, 99, 78, 0.16);
  }

  .command-search-icon {
    color: #8a7b6b;
    font-size: 0.9rem;
  }

  .command-input {
    width: 100%;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    color: #241c16;
    outline: none;
  }

  .command-input::placeholder {
    color: #9d9186;
  }

  .command-list {
    max-height: 18rem;
    overflow: auto;
    padding: 0.4rem;
  }

  .command-heading {
    padding: 0.45rem 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a7b6b;
  }

  .command-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.7rem;
    color: #241c16;
    cursor: default;
  }

  .command-item[data-selected] {
    background: #ece4d9;
  }

  .command-shortcut {
    margin-left: auto;
    color: #8a7b6b;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .command-item-disabled {
    color: #a49a90;
  }

  .command-separator {
    height: 1px;
    margin: 0.35rem 0;
    background: rgba(115, 99, 78, 0.16);
  }

  .command-empty {
    padding: 0.9rem;
    text-align: center;
    color: #8a7b6b;
    font-size: 0.9rem;
  }

  .command-dialog-trigger {
    border: 1px solid #1d1712;
    background: #1d1712;
    color: #f9f6f2;
    padding: 0.65rem 1rem;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .command-dialog-overlay {
    position: fixed;
    inset: 0;
    background: rgba(17, 13, 10, 0.45);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 50;
  }

  .command-dialog-overlay[data-open] {
    opacity: 1;
  }

  .command-dialog-overlay[data-starting-style],
  .command-dialog-overlay[data-ending-style] {
    opacity: 0;
  }

  .command-dialog-panel {
    position: fixed;
    top: 16%;
    left: 50%;
    transform: translateX(-50%);
    width: min(calc(100% - 2rem), 38rem);
    padding: 1rem;
    border: 1px solid #d7d2cc;
    background: #f8f3ec;
    box-shadow: 0 24px 60px rgba(25, 20, 15, 0.2);
    opacity: 0;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    z-index: 60;
