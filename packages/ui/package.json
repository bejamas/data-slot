{
  "name": "@data-slot/ui",
  "version": "0.2.106",
  "type": "module",
  "sideEffects": false,
  "description": "Headless UI components for vanilla JavaScript. Convenience re-exports from @data-slot/* packages.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "default": "./dist/core.js"
    },
    "./tabs": {
      "types": "./dist/tabs.d.ts",
      "import": "./dist/tabs.js",
      "require": "./dist/tabs.cjs",
      "default": "./dist/tabs.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js",
      "require": "./dist/dialog.cjs",
      "default": "./dist/dialog.js"
    },
    "./accordion": {
      "types": "./dist/accordion.d.ts",
      "import": "./dist/accordion.js",
      "require": "./dist/accordion.cjs",
      "default": "./dist/accordion.js"
    },
    "./popover": {
      "types": "./dist/popover.d.ts",
      "import": "./dist/popover.js",
      "require": "./dist/popover.cjs",
      "default": "./dist/popover.js"
    },
    "./hover-card": {
      "types": "./dist/hover-card.d.ts",
      "import": "./dist/hover-card.js",
      "require": "./dist/hover-card.cjs",
      "default": "./dist/hover-card.js"
    },
    "./tooltip": {
      "types": "./dist/tooltip.d.ts",
      "import": "./dist/tooltip.js",
      "require": "./dist/tooltip.cjs",
      "default": "./dist/tooltip.js"
    },
    "./collapsible": {
      "types": "./dist/collapsible.d.ts",
      "import": "./dist/collapsible.js",
      "require": "./dist/collapsible.cjs",
      "default": "./dist/collapsible.js"
    },
    "./navigation-menu": {
      "types": "./dist/navigation-menu.d.ts",
      "import": "./dist/navigation-menu.js",
      "require": "./dist/navigation-menu.cjs",
      "default": "./dist/navigation-menu.js"
    },
    "./dropdown-menu": {
      "types": "./dist/dropdown-menu.d.ts",
      "import": "./dist/dropdown-menu.js",
      "require": "./dist/dropdown-menu.cjs",
      "default": "./dist/dropdown-menu.js"
    },
    "./toggle": {
      "types": "./dist/toggle.d.ts",
      "import": "./dist/toggle.js",
      "require": "./dist/toggle.cjs",
      "default": "./dist/toggle.js"
    },
    "./toggle-group": {
      "types": "./dist/toggle-group.d.ts",
      "import": "./dist/toggle-group.js",
      "require": "./dist/toggle-group.cjs",
      "default": "./dist/toggle-group.js"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js",
      "require": "./dist/select.cjs",
      "default": "./dist/select.js"
    },
    "./combobox": {
      "types": "./dist/combobox.d.ts",
      "import": "./dist/combobox.js",
      "require": "./dist/combobox.cjs",
      "default": "./dist/combobox.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@data-slot/core": "workspace:*",
    "@data-slot/tabs": "workspace:*",
    "@data-slot/dialog": "workspace:*",
    "@data-slot/accordion": "workspace:*",
    "@data-slot/popover": "workspace:*",
    "@data-slot/hover-card": "workspace:*",
    "@data-slot/tooltip": "workspace:*",
    "@data-slot/collapsible": "workspace:*",
    "@data-slot/navigation-menu": "workspace:*",
    "@data-slot/dropdown-menu": "workspace:*",
    "@data-slot/toggle": "workspace:*",
    "@data-slot/toggle-group": "workspace:*",
    "@data-slot/select": "workspace:*",
    "@data-slot/combobox": "workspace:*"
  },
  "keywords": [
    "headless",
    "ui",
    "components",
    "vanilla",
    "data-slot"
  ],
  "license": "MIT",
  "homepage": "https://github.com/bejamas/data-slot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bejamas/data-slot.git",
    "directory": "packages/ui"
  }
}
