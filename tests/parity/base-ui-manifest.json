{
  "sourceRepo": "https://github.com/mui/base-ui",
  "sourceCheckout": {
    "path": "/tmp/base-ui",
    "checkoutDate": "2026-02-25"
  },
  "strategy": "parity-smoke",
  "components": [
    {
      "name": "dialog",
      "baseUiSources": [
        "packages/react/src/dialog/root/DialogRoot.test.tsx"
      ],
      "scenarios": [
        {
          "id": "dialog-outside-primary-click",
          "status": "implemented",
          "localTest": "packages/dialog/src/index.test.ts::closes on click outside content"
        },
        {
          "id": "dialog-ignore-non-primary-click",
          "status": "implemented",
          "localTest": "packages/dialog/src/index.test.ts::does not close on non-primary overlay click (Base UI parity)"
        }
      ]
    },
    {
      "name": "select",
      "baseUiSources": [
        "packages/react/src/select/trigger/SelectTrigger.test.tsx"
      ],
      "scenarios": [
        {
          "id": "select-disabled-trigger-native-focus-behavior",
          "status": "implemented",
          "localTest": "packages/select/src/index.test.ts::uses native disabled button behavior for disabled trigger (Base UI parity)"
        }
      ]
    },
    {
      "name": "tooltip",
      "baseUiSources": [
        "packages/react/src/tooltip/root/TooltipRoot.test.tsx"
      ],
      "scenarios": [
        {
          "id": "tooltip-click-before-delay-does-not-open",
          "status": "implemented",
          "localTest": "packages/tooltip/src/index.test.ts::does not open when trigger is clicked before delay duration (Base UI parity)"
        },
        {
          "id": "tooltip-click-after-open-closes",
          "status": "implemented",
          "localTest": "packages/tooltip/src/index.test.ts::closes when trigger is clicked after opening (Base UI parity)"
        }
      ]
    },
    {
      "name": "hover-card",
      "baseUiSources": [
        "packages/react/src/preview-card/root/PreviewCardRoot.test.tsx"
      ],
      "scenarios": [
        {
          "id": "hover-card-open-close-delays",
          "status": "already-covered",
          "localTest": "packages/hover-card/src/index.test.ts::opens on pointerenter (non-touch) after delay"
        }
      ]
    },
    {
      "name": "combobox",
      "baseUiSources": [
        "packages/react/src/autocomplete/root/AutocompleteRoot.test.tsx",
        "packages/react/src/combobox/clear/ComboboxClear.test.tsx"
      ],
      "scenarios": [
        {
          "id": "tab-close-after-enter-then-retype",
          "status": "implemented",
          "sourceCase": "closes popup on Tab after selecting with Enter and typing again",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:tab-close-after-enter-then-retype"
        },
        {
          "id": "auto-highlight-on-typing",
          "status": "implemented",
          "sourceCase": "highlights the first item when typing and keeps it during filtering",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:auto-highlight-on-typing"
        },
        {
          "id": "activedescendant-follows-filtering",
          "status": "implemented",
          "sourceCase": "links aria-activedescendant to the highlighted item after filtering",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:activedescendant-follows-filtering"
        },
        {
          "id": "no-initial-highlight-without-auto-highlight",
          "status": "implemented",
          "sourceCase": "does not highlight first/last item when pressing ArrowDown/ArrowUp initially",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:no-initial-highlight-without-auto-highlight"
        },
        {
          "id": "highlight-first-on-arrowdown-with-auto-highlight",
          "status": "implemented",
          "sourceCase": "highlights the first item when opening via ArrowDown",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:highlight-first-on-arrowdown-with-auto-highlight"
        },
        {
          "id": "escape-closes-open-popup",
          "status": "implemented",
          "sourceCase": "does not highlight on open via click or when pressing arrow keys initially",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:escape-closes-open-popup"
        },
        {
          "id": "tab-closes-and-restores-committed-label",
          "status": "implemented",
          "sourceCase": "closes popup on Tab after selecting with Enter and typing again",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:tab-closes-and-restores-committed-label"
        },
        {
          "id": "clear-focuses-input-without-opening",
          "status": "implemented",
          "sourceCase": "click clears selected value and focuses input",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:clear-focuses-input-without-opening"
        },
        {
          "id": "disabled-prevents-open",
          "status": "implemented",
          "sourceCase": "behavioral equivalent: disabled interaction contract",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:disabled-prevents-open"
        },
        {
          "id": "outside-pointerdown-dismisses",
          "status": "implemented",
          "sourceCase": "keeps the latest pointer highlight on outside blur when behavior is \"always\"",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:outside-pointerdown-dismisses"
        },
        {
          "id": "filtering-empty-state-toggle",
          "status": "implemented",
          "sourceCase": "highlights the first item when typing and keeps it during filtering",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:filtering-empty-state-toggle"
        },
        {
          "id": "enter-selects-highlighted-item",
          "status": "implemented",
          "sourceCase": "closes popup on Tab after selecting with Enter and typing again",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:enter-selects-highlighted-item"
        },
        {
          "id": "required-validation-empty-vs-selected",
          "status": "implemented",
          "sourceCase": "triggers native validation when required and empty",
          "localTest": "packages/combobox/src/index.test.ts::parity:combobox:required-validation-empty-vs-selected"
        }
      ]
    }
  ]
}
